# Form submissions are emailed via Resend (https://resend.com).
# Copy this file to .env for local development, and set the same values
# in Vercel → Project → Settings → Environment Variables for deployment.

# Required: your Resend API key (https://resend.com/api-keys)
RESEND_API_KEY=

# Required: inbox that receives form submissions
CONTACT_TO_EMAIL=you@example.com

# Optional: verified Resend sender. If unset, falls back to onboarding@resend.dev
# (which can only deliver to the email on your own Resend account).
# CONTACT_FROM_EMAIL=ProjectKix <hello@yourdomain.com>
